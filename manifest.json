{
  "manifest_version": 3,
  "name": "RSVP Speed Read",
  "version": "1.0.0",
  "description": "Speed read any web page using RSVP method with a keyboard shortcut",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "speed-read": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Start speed reading"
    }
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "RSVP Speed Read"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scout.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}